# Brukes av `gcloud builds submit` — hold upload liten (unngå GB med data/modeller).
# Se: gcloud topic gcloudignore

.git/
.gcloudignore
.gitignore

# Store data / treningsfiler
data/
runs/
*.cache

# Modeller og zip (unntatt det som trengs i image — Tripletex trenger ikke .pt)
*.pt
*.pt.bak
*.pth
*.onnx
*.zip

# Python-miljøer
.venv/
venv/
__pycache__/
*.egg-info/

# Andre oppgaver (Dockerfile kopierer kun tripletex/, men vi trenger ikke laste dem)
norgesgruppen/
astar/

# IDE / OS
.idea/
.vscode/
.DS_Store
__MACOSX/
